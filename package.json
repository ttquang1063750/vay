    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "angular-eslint": "^21.3.1",
    "cypress": "^15.12.0",
    "eslint": "^10.0.3",
